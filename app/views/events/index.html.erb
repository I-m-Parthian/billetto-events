<h1>Upcoming Events</h1>

<div class="events">
  <% @events.each do |event| %>
    <div class="event-card">

      <% if event.image_link.present? %>
        <img src="<%= event.image_link %>" alt="<%= event.title %>" width="300">
      <% end %>

      <h2>
        <%= link_to event.title, event_path(event) %>
      </h2>

      <p>
        <strong>Start Date:</strong>
        <%= event.start_date.strftime("%d %B %Y, %H:%M") %>
      </p>

      <p>
        <strong>End Date:</strong>
        <%= event.end_date.strftime("%d %B %Y, %H:%M") %>
      </p>

      <p>
        <%= truncate(event.description, length: 200) %>
      </p>

      <p>
       👍 <%= event.upvotes %>
       👎 <%= event.downvotes %>
      </p>

      <%= button_to "Upvote", event_upvote_path(event), method: :post %>
      <%= button_to "Downvote", event_downvote_path(event), method: :post %>
    </div>

    <hr>
  <% end %>
</div>